# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# Anthropic API Key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail credentials for sending confirmation emails
# Use a Gmail App Password (not your main password)
# Guide: https://support.google.com/accounts/answer/185833
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Email address that receives meeting notifications
RECEPTIONIST_EMAIL=your_email@example.com

# Frontend URL (for CORS) — set to your Vercel URL in production
FRONTEND_URL=http://localhost:5173
